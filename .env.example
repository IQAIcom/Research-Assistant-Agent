# ADK-TS framework debug logs (optional)
ADK_DEBUG=false

# LLM provider API key (required)
# Get a key from https://aistudio.google.com/api-keys
GOOGLE_API_KEY=your_google_api_key_here

# LLM model name (optional)
LLM_MODEL=gemini-2.5-flash

# Tavily API key (required for Tavily integration)
# Get a key from https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
